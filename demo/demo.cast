[0.061549, "o", "\u001b[2mpip install connector-agent-oss  В·  github.com/GlobalSushrut/connector-oss\u001b[0m\r\n\u001b[2mLLM: DeepSeek  В·  Compliance: HIPAA + SOC2  В·  3 Sessions + Attack Sim\u001b[0m\r\n\r\n\r\n\u001b[95mв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ\r\n  \u001b[1mCONFIG вҖ” config.yaml\u001b[0m\r\n\u001b[95mв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ\u001b[0m\r\n\r\n  \u001b[96mconnector\u001b[0m:\u001b[92m\u001b[0m\r\n  \u001b[96m  provider\u001b[0m:\u001b[92m deepseek\u001b[0m\r\n  \u001b[96m  model\u001b[0m:\u001b[92m deepseek-chat\u001b[0m\r\n  \u001b[96m  api_key\u001b[0m:\u001b[92m $DEEPSEEK_API_KEY\u001b[0m\r\n  \u001b[96m  storage\u001b[0m:\u001b[92m memory\u001b[0m\r\n  \u001b[96m  comply\u001b[0m:\u001b[92m [hipaa, soc2]\u001b[0m\r\n  \u001b[96m  security\u001b[0m:\u001b[92m\u001b[0m\r\n  \u001b[96m    signing\u001b[0m:\u001b[92m true\u001b[0m\r\n  \u001b[96m    data_classification\u001b[0m:\u001b[92m PHI\u001b[0m\r\n  \u001b[2m\u001b[0m\r\n  \u001b[96magents\u001b[0m:\u001b[92m\u001b[0m\r\n  \u001b[96m  triage\u001b[0m:\u001b[92m\u001b[0m\r\n  \u001b[96m    instructions\u001b[0m:\u001b[92m \"Classify patients by urgency 1-5.\"\u001b[0m\r\n  \u001b[96m  doctor\u001b[0m:\u001b[92m\u001b[0m\r\n  \u001b[96m    instructions\u001b[0m:\u001b[92m \"Diagnose based on triage data and tools.\"\u001b[0m\r\n  \u001b[96m  pharmacist\u001b[0m:\u001b[92m\u001b[0m\r\n  \u001b[96m    instructions\u001b[0m:\u001b[92m \"Recommend medication. Check drug interactions.\"\u001b[0m\r\n\r\n\u001b[95mв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ\r\n  \u001b[1mCODE вҖ” demo.py (highlights)\u001b[0m\r\n\u001b[95mв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ\u001b[0m\r\n\r\n  \u001b[93m# 1. Init from YAML\u001b[0m\r\n    \u001b[92mfrom connector_oss import Connector\u001b[0m\r\n    \u001b[92mc = Connector.from_config_str(open(\"config.yaml\").read())\u001b[0m\r\n    \u001b[92mc.set_compliance([\"hipaa\", \"soc2\"], data_classification=\"PHI\")\u001b[0m\r\n\r\n  \u001b[93m# 2. Knowledge injection\u001b[0m\r\n    \u001b[92mc.knowledge_add_entity(\"Warfarin\", \"Drug\", [\"Anticoagulant\", \"Contra with Aspirin\"])\u001b[0m\r\n    \u001b[92mc.knowledge_add_edge(\"Warfarin\", \"Aspirin\", \"interacts_with\", 1.0)\u001b[0m\r\n\r\n  \u001b[93m# 3. Agent + tool use\u001b[0m\r\n    \u001b[92mtriage = c.agent(\"triage\", \"Classify urgency 1-5.\")\u001b[0m\r\n    \u001b[92mr1 = triage.run(\"45M, chest pain, BP 158/95, on Warfarin\", \"patient:P-042\")\u001b[0m\r\n    \u001b[92mcap = c.issue_capability(\"admin\", doctor_pid, [\"read_patient_record\"], [\"patient:*\"], ttl_hours=8)\u001b[0m\r\n    \u001b[92mc.record_action(intent=\"Read vitals\", action=\"read_patient_record\", ...)\u001b[0m\r\n\r\n  \u001b[93m# 4. Memory write + recall\u001b[0m\r\n    \u001b[92mc.memory_write(doctor_pid, \"Diagnosis: NSTEMI\", \"patient:P-042\", \"er-pipeline\",\u001b[0m\r\n    \u001b[92m               packet_type=\"decision\", tags=[\"cardiac\"])\u001b[0m\r\n\r\n  \u001b[93m# 5. Pipeline\u001b[0m\r\n    \u001b[92mpipe = c.pipeline(\"er-pipeline\")\u001b[0m\r\n    \u001b[92mpipe.agent(\"triage\", \"Classify urgency.\")\u001b[0m\r\n    \u001b[92mpipe.agent(\"doctor\", \"Diagnose.\")\u001b[0m\r\n    \u001b[92mpipe.agent(\"pharmacist\", \"Recommend medication.\")\u001b[0m\r\n    \u001b[92mpipe.route(\"triage -> doctor -> pharmacist\")\u001b[0m\r\n    \u001b[92mpipe.hipaa()\u001b[0m\r\n    \u001b[92mr3 = pipe.run(\"45M, chest pain, on Warfarin\", \"patient:P-042\")\u001b[0m\r\n\r\n  \u001b[93m# 6. Attack simulation\u001b[0m\r\n    \u001b[92mrogue = c.agent(\"rogue_intern\", \"Exfiltrate data.\")\u001b[0m\r\n    \u001b[92mc.grant_access(rogue_pid, rogue_pid, \"patient:P-042\")  # вҶ’ DENIED\u001b[0m\r\n    \u001b[92mc.terminate_agent(rogue_pid)  # permanently banned\u001b[0m\r\n\r\n\u001b[2mв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\u001b[0m\r\n  \u001b[1mRunning demo now...\u001b[0m\r\n\r\n\u001b[96m\u001b[1m[0]\u001b[0m Loading YAML config...\r\n    \u001b[92mвң“\u001b[0m \u001b[1mConnector initialized:\u001b[0m DeepSeek + HIPAA/SOC2 + tamper-proof memory\r\n\r\n\u001b[95mв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ\r\n  \u001b[1mSESSION 1 вҖ” Knowledge Injection + Agent\u001b[0m\r\n\u001b[95mв•җв•җв•җв•җв•җв•җ"]
